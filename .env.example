# =============================================================
# Auto Tools — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha os valores necessários.
# O arquivo .env NUNCA deve ser commitado no Git.

# CHAVE_LOGIN: Chave Fernet para criptografia do cofre de senhas.
# Gerada automaticamente na primeira execução (setup_db.py).
# NÃO altere após a criação — perderá acesso às senhas salvas.
CHAVE_LOGIN=

# DATABASE_NAME: Nome do arquivo SQLite do banco de dados.
DATABASE_NAME=Userbank.db
